# Copy to .env and adjust. .env is gitignored.

# --- Database (shared by packages/db and apps/api) ---
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/paybridge?schema=public"

# --- API (apps/api) ---
API_PORT=4000
NODE_ENV=development

# JWT for the dashboard session (use a long random string in real use)
JWT_SECRET="dev-only-change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Default sandbox currency (ISO 4217)
DEFAULT_CURRENCY="MYR"

# --- Web (apps/web) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"
