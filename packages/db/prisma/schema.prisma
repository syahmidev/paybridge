// PayBridge — Prisma schema
// Phase 1 models: Merchant, ApiKey, Payment.
// Phase 2 will add WebhookEndpoint + WebhookDelivery.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApiKeyType {
  secret
  publishable
}

// Stripe-style payment lifecycle. Transitions are enforced in the API layer.
enum PaymentStatus {
  requires_payment_method
  processing
  succeeded
  failed
  canceled
}

enum WebhookDeliveryStatus {
  pending
  succeeded
  failed
}

model Merchant {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  apiKeys          ApiKey[]
  payments         Payment[]
  webhookEndpoints WebhookEndpoint[]

  @@map("merchants")
}

model ApiKey {
  id         String     @id @default(cuid())
  merchantId String
  type       ApiKeyType
  // Secret keys are stored hashed; the plaintext is shown once on creation.
  // Publishable keys are not secret and may be stored/displayed in full.
  keyHash    String     @unique
  // Short display prefix, e.g. "sk_test_a1b2" — safe to show in lists.
  prefix     String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime   @default(now())

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([merchantId])
  @@map("api_keys")
}

model Payment {
  id          String        @id @default(cuid())
  merchantId  String
  // Amount in integer minor units (e.g. cents). Never a float.
  amount      Int
  currency    String        @db.VarChar(3)
  status      PaymentStatus @default(requires_payment_method)
  description String?
  metadata    Json?
  // Idempotency-Key from POST /v1/payments; unique per merchant.
  idempotencyKey String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([merchantId, idempotencyKey])
  @@index([merchantId])
  @@map("payments")
}

model WebhookEndpoint {
  id String @id @default(cuid())
  merchantId String
  url String
  // Per-endpoint HMAC signing secret (whsec_...). Displayable so the merchant
  // can verify signatures; not a credential for calling our API.
  signingSecret String
  enabled Boolean @default(true)
  createdAt DateTime @default(now())

  merchant   Merchant          @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([merchantId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id String @id @default(cuid())
  endpointId String
  // Event identity (shared across endpoints for the same event), e.g. evt_...
  eventId String
  eventType String
  payload Json
  status WebhookDeliveryStatus @default(pending)
  attempts Int @default(0)
  responseStatus Int?
  error String?
  lastAttemptAt DateTime?
  nextRetryAt DateTime?
  createdAt DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId])
  @@index([status])
  @@map("webhook_deliveries")
}
